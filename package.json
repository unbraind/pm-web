{
  "name": "pm-web",
  "version": "1.0.0",
  "description": "Web UI for pm-cli",
  "type": "module",
  "files": [
    "dist/",
    "public/",
    "sql/",
    "manifest.json",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:graph && npm run build:server && npm run build:frontend",
    "build:graph": "cd extensions/pm-graph && npm run build",
    "build:server": "tsc",
    "start": "node dist/server.js",
    "typecheck": "npm run typecheck:graph && npm run typecheck:server && npm run typecheck:frontend",
    "typecheck:graph": "cd extensions/pm-graph && npm run typecheck",
    "typecheck:server": "tsc --noEmit",
    "typecheck:frontend": "cd public && npx tsc --noEmit",
    "build:frontend": "cd public && npx tsc",
    "build:all": "npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "neo4j-driver": "^5.28.3",
    "pg": "^8.14.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@unbrained/pm-cli": "latest",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
