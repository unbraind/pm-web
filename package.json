{
  "name": "pm-web",
  "version": "1.0.0",
  "description": "Web UI for pm-cli",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "build:frontend": "cd public && npx tsc",
    "build:all": "npm run build && npm run build:frontend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@unbrained/pm-cli": "^2026.5.10",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
