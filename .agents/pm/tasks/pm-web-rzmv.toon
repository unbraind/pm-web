files[1]{path,scope,note}:
  .github/workflows/release.yml,project,"runs-on: self-hosted -> ubuntu-latest"
close_reason: "Proven: dispatched run 27430061038 executed on ubuntu-latest (previous runs queued 24h on self-hosted and auto-cancelled; a stale queued run also blocked the concurrency group and was cancelled). The run reached the changelog step — queue defect resolved. Its changelog:check failure is a separate pre-existing bug tracked in a follow-up item."
